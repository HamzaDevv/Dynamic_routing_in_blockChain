{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/v1", "destination": "/index_v1.html" },
    { "source": "/v2", "destination": "/index_v2.html" },
    { "source": "/v3", "destination": "/index_v3.html" },
    { "source": "/dapp", "destination": "/index_dapp.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
